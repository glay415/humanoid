# Legacy single-instance paths (pre Wave 11 / instance manager)
chroma_db/
storage_data/

# Instances — runtime per-character data is local to each developer.
# Chat / ChromaDB / SQLite / state.json 모두 git 으로 공유하지 않는다.
# 캐릭터 공유가 필요하면 명시적 export 경로를 따로 만들 것.
# (이전 정책: _default 만 ignore + 나머지 추적 → 사용자 요청으로 폐기)
instances/

# Secrets
.env
.env.local
*.key

